{
  "name": "pd-markdown-${package-name}",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin typescript && rm -rf dist/types",
    "clean": "rm -rf dist *.tsbuildinfo .rollup.cache"
  },
  "dependencies": {
    "pd-markdown-utils": "workspace:*"
  },
  "sideEffects": false
}
